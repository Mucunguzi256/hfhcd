---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  slug?: string;
  category?: string;
}

const {
  title = '[Cause Title Placeholder]',
  description = '[Add your cause description here. This should describe the problem and how your organization helps.]',
  image = 'https://placehold.co/600x400/2C5F2D/97BC62?text=Cause+Image',
  slug = '#',
  category = 'Community',
} = Astro.props;
---

<a
  href={slug}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:shadow-primary/10 transition-all hover:-translate-y-1"
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute top-4 left-4">
      <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-primary text-sm font-medium rounded-full">
        {category}
      </span>
    </div>
  </div>
  <div class="p-6">
    <h3 class="font-display text-xl font-semibold text-earth-900 mb-3 group-hover:text-primary transition-colors">
      {title}
    </h3>
    <p class="text-earth-600 line-clamp-3">{description}</p>
    <div class="mt-4 flex items-center text-primary font-medium">
      <span>Learn more</span>
      <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>