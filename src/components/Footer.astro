---
const currentYear = new Date().getFullYear();
---

<footer class="bg-earth-900 text-earth-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center overflow-hidden shadow-soft">
            <img 
              src="/images/hfhcd-logo.jpg" 
              alt="HFHCD Logo" 
              class="w-full h-full object-cover"
            />
          </div>
          <span class="font-display text-2xl font-semibold text-white">
            HFHCD
          </span>
        </div>
        <p class="text-earth-300 text-lg max-w-md mb-6">
          Making a Difference Since 2020 - Bringing Hope to Humanity
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-earth-800 flex items-center justify-center text-earth-300 hover:bg-primary hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.295 1.508 6.742-1.162-.037-2.252-.355-3.193-.873-.966 1.674-2.936 2.887-5.324 2.887-.435 0-.855-.025-1.272-.074 2.421 1.737 5.292 2.658 8.377 2.695-3.947 3.082-8.943 4.062-13.446 3.56-.952.488-1.959.769-2.977.769-1.213 0-2.365-.296-3.337-.806 6.512 4.128 14.201 4.128 20.665 4.128 1.652 0 3.258-.137 4.781-.401 1.608-1.263 2.886-3.054 3.51-5.196l.062-.005z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-earth-800 flex items-center justify-center text-earth-300 hover:bg-primary hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.012-3.584.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-earth-800 flex items-center justify-center text-earth-300 hover:bg-primary hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-display text-lg font-semibold text-white mb-4">Quick Links</h4>
        <ul class="space-y-3">
          <li><a href="/about" class="text-earth-300 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/causes" class="text-earth-300 hover:text-white transition-colors">Our Causes</a></li>
          <li><a href="/donate" class="text-earth-300 hover:text-white transition-colors">Donate</a></li>
          <li><a href="/contact" class="text-earth-300 hover:text-white transition-colors">Contact</a></li>
          <li><a href="/admin" class="text-earth-300 hover:text-white transition-colors">Admin</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display text-lg font-semibold text-white mb-4">Contact Info</h4>
        <ul class="space-y-3 text-earth-300">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Kampala, Uganda</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>info@hopeforhumanity.org</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>+256 700 000 000</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-earth-800 mt-12 pt-8 text-center text-earth-400">
      <p>&copy; {currentYear} Hope for Humanity and Community Development. All rights reserved.</p>
      <p class="text-sm mt-2">Registered NGO in Uganda</p>
    </div>
  </div>
</footer>