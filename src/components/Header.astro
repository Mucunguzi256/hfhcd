---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/causes', label: 'Causes' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/95 backdrop-blur-md border-b border-earth-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center overflow-hidden shadow-soft">
          <img 
            src="/images/hfhcd-logo.jpg" 
            alt="HFHCD Logo" 
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <span class="font-display text-lg lg:text-xl font-semibold text-primary hidden sm:block">
          HFHCD
        </span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-earth-700 hover:text-primary font-medium transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        <a
          href="/donate"
          class="bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-full font-medium transition-all hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5"
        >
          Donate
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-earth-700"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-earth-100">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-earth-700 hover:text-primary font-medium py-2"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>