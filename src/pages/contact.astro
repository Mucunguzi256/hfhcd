---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - Hope for Humanity">
  <Header />

  <main class="pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-earth-900 mb-6">Contact Us</h1>
      <p class="text-xl text-earth-600 max-w-3xl">
        We would love to hear from you. Whether you have a question, want to volunteer, or are interested in partnering with us — reach out!
      </p>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <h2 class="font-display text-2xl font-bold text-earth-900 mb-6">Get In Touch</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-medium text-earth-900 mb-2">Location</h3>
              <p class="text-earth-600">Kampala, Uganda</p>
            </div>
            <div>
              <h3 class="font-medium text-earth-900 mb-2">Email</h3>
              <p class="text-earth-600">info@hopeforhumanity.org</p>
            </div>
            <div>
              <h3 class="font-medium text-earth-900 mb-2">Phone</h3>
              <p class="text-earth-600">+256 700 000 000</p>
            </div>
            <div>
              <h3 class="font-medium text-earth-900 mb-2">Working Hours</h3>
              <p class="text-earth-600">Monday – Friday: 8am – 5pm</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h2 class="font-display text-2xl font-bold text-earth-900 mb-6">Send a Message</h2>
          <form class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-earth-700 mb-1">Name</label>
              <input type="text" id="name" class="w-full px-4 py-3 border border-earth-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-earth-700 mb-1">Email</label>
              <input type="email" id="email" class="w-full px-4 py-3 border border-earth-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="your@email.com" />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-earth-700 mb-1">Subject</label>
              <input type="text" id="subject" class="w-full px-4 py-3 border border-earth-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="What is this about?" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-earth-700 mb-1">Message</label>
              <textarea id="message" rows="4" class="w-full px-4 py-3 border border-earth-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Your message..."></textarea>
            </div>
            <button type="submit" class="w-full px-6 py-3 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>