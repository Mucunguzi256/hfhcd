---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Donate - Hope for Humanity">
  <Header />

  <main class="pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-earth-900 mb-6">Donate with Offline Donation</h1>
      <p class="text-xl text-earth-600 max-w-3xl">
        Thank you for choosing to support Hope for Humanity and Community Development. To complete your donation via bank transfer, please follow these instructions carefully.
      </p>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-cream rounded-3xl p-8 lg:p-12 mb-12">
        <h2 class="font-display text-2xl font-bold text-earth-900 mb-6">Step 1: Make your bank transfer</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <h3 class="font-display text-xl font-semibold text-earth-900 mb-4">Bank Details</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">Bank Name</span>
                <span class="font-medium text-earth-900">Stanbic Bank Uganda</span>
              </div>
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">Branch</span>
                <span class="font-medium text-earth-900">Mbale Branch</span>
              </div>
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">Account Name</span>
                <span class="font-medium text-earth-900">HOPE FOR HUMANITY AND COMMUNITY DEVELOPMENT</span>
              </div>
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">Account Number</span>
                <span class="font-medium text-earth-900">9030021210861</span>
              </div>
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">Sort Code</span>
                <span class="font-medium text-earth-900">040147</span>
              </div>
              <div class="flex justify-between py-2 border-b border-earth-100">
                <span class="text-earth-600">SWIFT Code</span>
                <span class="font-medium text-earth-900">SBICUGKXXXX</span>
              </div>
              <div class="flex justify-between py-2">
                <span class="text-earth-600">Bank Address</span>
                <span class="font-medium text-earth-900 text-right">Republic Street, Mbale, Uganda</span>
              </div>
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-white rounded-2xl p-6 shadow-sm">
              <h3 class="font-display text-xl font-semibold text-earth-900 mb-4">Step 2: Add your reference</h3>
              <p class="text-earth-600">
                Include your full name and email address in the transfer reference (e.g., "Donation – John Doe – johndoe@email.com"). This helps us match your donation to you.
              </p>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm">
              <h3 class="font-display text-xl font-semibold text-earth-900 mb-4">Step 3: Notify us</h3>
              <p class="text-earth-600 mb-4">
                After sending the transfer, please notify us by email at info@hopeforhumanity.org or WhatsApp us on +256771173835. Include your name, the amount sent, and the date of transfer.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-primary text-white rounded-2xl p-8 mb-12">
        <h2 class="font-display text-2xl font-bold mb-4">What happens next?</h2>
        <p class="text-white/80 mb-4">
          Once we confirm your transfer, we will mark your donation as "Complete" in our system and send you a confirmation email. You will also be able to see your donation in your Donor Dashboard (if you have one).
        </p>
      </div>

      <div class="text-center">
        <p class="text-earth-600 mb-4">Thank you for your generosity – you are making a real difference.</p>
        <p class="text-earth-600">Need help? Contact us at: info@hopeforhumanity.org 📞 +256771173835</p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>